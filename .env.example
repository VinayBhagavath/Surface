# Copy to .env.local and fill in. NEVER commit real secrets.

# xAI / Grok — get a key at https://console.x.ai
XAI_API_KEY=
XAI_BASE_URL=https://api.x.ai/v1
XAI_MODEL=grok-4.3

# Inngest — blank for local dev server; set both in Vercel for production.
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=
INNGEST_DEV=1

NEXT_PUBLIC_APP_URL=http://localhost:3000
