# Copy to .env.local and fill in. NEVER commit real secrets.

# xAI / Grok — get a key at https://console.x.ai
# Powers reasoning, Live Search, the live patient summary, AND the agent voice.
XAI_API_KEY=
XAI_BASE_URL=https://api.x.ai/v1
XAI_MODEL=grok-4.3
# Optional: disable xAI Live Search for out-of-table genes (on by default).
XAI_WEB_SEARCH=1

# Agent thinking VOICE (xAI Text-to-Speech, POST /v1/tts). Optional — the spoken
# layer fails silent if absent. Defaults shown; voice ids: eve|ara|rex|sal|leo.
XAI_TTS_MODEL=grok-voice-think-fast-1.1
XAI_TTS_VOICE=eve
XAI_TTS_SPEED=0.95

# Inngest — blank for local dev server; set both in Vercel for production.
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=
INNGEST_DEV=1

# Optional durable store (Vercel KV / Upstash). Without it, dev uses memory.
KV_REST_API_URL=
KV_REST_API_TOKEN=

NEXT_PUBLIC_APP_URL=http://localhost:3000
